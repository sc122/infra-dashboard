# ═══════════════════════════════════════════════════════════════
# Infra Dashboard — Environment Variables
# Copy this file to .env.local and fill in your values.
# ═══════════════════════════════════════════════════════════════

# ─── Dashboard Settings ───────────────────────────────────────

# Password to access the dashboard (required)
DASHBOARD_PASSWORD=

# Display name shown in sidebar
NEXT_PUBLIC_DASHBOARD_NAME=Infra Dashboard

# Your dashboard URL (auto-detected on Vercel, set manually otherwise)
# NEXT_PUBLIC_DASHBOARD_URL=https://your-dashboard.vercel.app

# ─── Platform Tokens (all optional — connect what you use) ────

# Vercel: https://vercel.com/account/tokens
MY_VERCEL_TOKEN=
VERCEL_TEAM_ID=
NEXT_PUBLIC_VERCEL_TEAM_SLUG=

# Netlify: https://app.netlify.com/user/applications#personal-access-tokens
NETLIFY_TOKEN=

# Cloudflare: https://dash.cloudflare.com/profile/api-tokens (Zone:Read, DNS:Read)
CF_API_TOKEN=
CF_ACCOUNT_ID=
NEXT_PUBLIC_CF_ACCOUNT_ID=

# Hetzner Cloud: https://console.hetzner.cloud → Security → API Tokens
HETZNER_API_TOKEN=

# GitHub: https://github.com/settings/tokens (repo scope)
GITHUB_TOKEN=
NEXT_PUBLIC_GITHUB_USERNAME=

# ─── Notifications (optional) ─────────────────────────────────

# Telegram: Create bot via @BotFather, get chat ID from /getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── VPS Configuration (optional) ─────────────────────────────

# Your primary domain on VPS (for auto-detecting Docker project subdomains)
NEXT_PUBLIC_DEPLOY_DOMAIN=

# ─── Vercel Internal (auto-set, do not change) ────────────────
# VERCEL_URL=
# CRON_SECRET=
